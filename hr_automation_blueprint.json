            "id": 10,
            "module": "google-email:ActionSendEmail",
            "version": 1,
            "parameters": {
                "account": 8969790
            },
            "mapper": {
                "cc": [],
                "to": "{{14.`1`}}",
                "bcc": [],
                "from": "",
                "html": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n<meta charset=\"utf-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n</head>\r\n<body style=\"margin:0; padding:0; background-color:#0a0a0f; font-family:'Segoe UI', Helvetica, Arial, sans-serif;\">\r\n  <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:radial-gradient(ellipse at top, #1a1230 0%, #0a0a0f 60%); padding:40px 0;\">\r\n    <tr>\r\n      <td align=\"center\">\r\n        <table role=\"presentation\" width=\"560\" cellpadding=\"0\" cellspacing=\"0\"\r\n               style=\"background:linear-gradient(160deg,#1c1730 0%,#120e1f 55%,#0d0a17 100%);\r\n                      border-radius:24px; overflow:hidden;\r\n                      border:1px solid #7a5cff;\r\n                      box-shadow:0 0 0 1px rgba(122,92,255,0.15), 0 20px 60px rgba(122,92,255,0.25), 0 0 90px rgba(255,111,145,0.15);\">\r\n\r\n          <!-- ribbon banner top -->\r\n          <tr>\r\n            <td style=\"background:linear-gradient(90deg,#ff6f91 0%,#ff9a5a 25%,#ffd45a 50%,#7a5cff 75%,#5ad1ff 100%); padding:6px 0; text-align:center;\">\r\n              <span style=\"font-family:Arial, sans-serif; font-size:11px; letter-spacing:4px; color:#0a0a0f; font-weight:700; text-transform:uppercase;\">\r\n                &#10024; A Special Day &#10024;\r\n              </span>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- confetti strip -->\r\n          <tr>\r\n            <td style=\"padding:22px 0 0 0; text-align:center; font-size:16px; letter-spacing:8px;\">\r\n              &#127882;&#8203; &#127881;&#8203; &#10024;&#8203; &#127880;&#8203; &#127882;&#8203; &#10024;&#8203; &#127881;\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- header -->\r\n          <tr>\r\n            <td style=\"padding:16px 0 4px 0; text-align:center;\">\r\n              <span style=\"font-family:Georgia,'Times New Roman',serif; font-size:44px; font-weight:bold;\r\n                           color:#ffd45a; text-shadow:0 0 30px rgba(255,154,90,0.45);\">\r\n                Happy Birthday!\r\n              </span>\r\n            </td>\r\n          </tr>\r\n          <tr>\r\n            <td style=\"text-align:center; padding-bottom:4px;\">\r\n              <span style=\"display:inline-block; width:100px; height:2px; background:linear-gradient(90deg,transparent,#ff9a5a,transparent);\"></span>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- balloons row -->\r\n          <tr>\r\n            <td align=\"center\" style=\"padding:14px 0 4px 0;\">\r\n              <table cellpadding=\"0\" cellspacing=\"0\">\r\n                <tr>\r\n                  <td style=\"font-size:30px; padding:0 8px;\">&#127880;</td>\r\n                  <td style=\"font-size:40px; padding:0 8px;\">&#127881;</td>\r\n                  <td style=\"font-size:50px; padding:0 10px;\">&#127882;</td>\r\n                  <td style=\"font-size:40px; padding:0 8px;\">&#127883;</td>\r\n                  <td style=\"font-size:30px; padding:0 8px;\">&#127880;</td>\r\n                </tr>\r\n              </table>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- PHOTO FRAME (glow + gradient ring) -->\r\n          <tr>\r\n            <td align=\"center\" style=\"padding:28px 0 4px 0;\">\r\n              <table cellpadding=\"0\" cellspacing=\"0\"\r\n                     style=\"background:linear-gradient(135deg,#ff9a5a 0%,#ff6f91 30%,#7a5cff 65%,#5ad1ff 100%);\r\n                            border-radius:22px; padding:7px;\r\n                            box-shadow:0 0 0 1px rgba(255,255,255,0.08), 0 10px 35px rgba(122,92,255,0.4), 0 0 70px rgba(255,111,145,0.35);\">\r\n                <tr>\r\n                  <td style=\"background-color:#120e1f; border-radius:18px; padding:8px;\">\r\n                    <table cellpadding=\"0\" cellspacing=\"0\" style=\"border-radius:14px; border:2px solid rgba(255,212,90,0.8);\">\r\n                      <tr>\r\n                        <td style=\"border-radius:14px; overflow:hidden; line-height:0;\">\r\n                          <img src=\"cid:employee_photo\" width=\"230\" height=\"230\"\r\n                               style=\"display:block; border-radius:12px; object-fit:cover;\"\r\n                               alt=\"{{14.`0`}}\" />\r\n                        </td>\r\n                      </tr>\r\n                    </table>\r\n                  </td>\r\n                </tr>\r\n              </table>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- sparkle accents under frame -->\r\n          <tr>\r\n            <td align=\"center\" style=\"padding:10px 0 0 0; font-size:16px; letter-spacing:10px;\">\r\n              <span style=\"color:#ffd45a;\">&#10022;</span>\r\n              <span style=\"color:#ff6f91;\">&#10022;</span>\r\n              <span style=\"color:#5ad1ff;\">&#10022;</span>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- name (this is the employee's name, kept short) -->\r\n          <tr>\r\n            <td align=\"center\" style=\"padding-top:18px;\">\r\n              <span style=\"font-family:Georgia,'Times New Roman',serif; font-size:32px; font-weight:bold;\r\n                           color:#ffe9b0; text-shadow:0 0 20px rgba(255,212,90,0.3);\">\r\n                {{14.`0`}}\r\n              </span>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- department badge -->\r\n          <tr>\r\n            <td align=\"center\" style=\"padding-top:6px; padding-bottom:4px;\">\r\n              <table cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:rgba(122,92,255,0.15); border:1px solid rgba(122,92,255,0.4); border-radius:20px;\">\r\n                <tr>\r\n                  <td style=\"padding:5px 18px;\">\r\n                    <span style=\"font-family:Arial, sans-serif; font-size:12px; letter-spacing:1.5px; color:#c9bfff; text-transform:uppercase;\">\r\n                      {{14.`3`}}\r\n                    </span>\r\n                  </td>\r\n                </tr>\r\n              </table>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- message card: small readable text, with fallback -->\r\n          <tr>\r\n            <td style=\"padding:26px 36px 8px 36px;\">\r\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"\r\n                     style=\"background:linear-gradient(135deg,rgba(255,111,145,0.08),rgba(122,92,255,0.08));\r\n                            border-radius:14px; border:1px solid rgba(255,212,90,0.25);\">\r\n                <tr>\r\n                  <td style=\"padding:20px 24px;\">\r\n                    <span style=\"font-family:Arial, sans-serif; font-size:14px; color:#ede9f7; line-height:1.7;\">\r\n                      {{ifempty(41.choices[1].message.content; \"Wishing you a fantastic birthday filled with joy, laughter, and everything that makes you happy. May the year ahead bring you great success and unforgettable memories. Have a wonderful celebration!\")}}\r\n                    </span>\r\n                  </td>\r\n                </tr>\r\n              </table>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- bottom decoration -->\r\n          <tr>\r\n            <td align=\"center\" style=\"padding:26px 0 10px 0;\">\r\n              <table cellpadding=\"0\" cellspacing=\"0\">\r\n                <tr>\r\n                  <td style=\"font-size:32px; padding:0 10px;\">&#127873;</td>\r\n                  <td style=\"font-size:32px; padding:0 10px;\">&#127775;</td>\r\n                  <td style=\"font-size:32px; padding:0 10px;\">&#127873;</td>\r\n                </tr>\r\n              </table>\r\n            </td>\r\n          </tr>\r\n\r\n          <tr>\r\n            <td style=\"text-align:center; padding-bottom:12px;\">\r\n              <span style=\"display:inline-block; width:100px; height:1px; background:linear-gradient(90deg,transparent,#3a3450,transparent);\"></span>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- footer -->\r\n          <tr>\r\n            <td align=\"center\" style=\"padding:6px 20px 28px 20px;\">\r\n              <span style=\"font-family:Arial, sans-serif; font-size:11px; color:#75708f;\">\r\n                Sent automatically by the HR &amp; Admin Team &middot; Omni Payments\r\n              </span>\r\n            </td>\r\n          </tr>\r\n        </table>\r\n      </td>\r\n    </tr>\r\n  </table>\r\n</body>\r\n</html>",
                "subject": "🎉 Happy Birthday, {{14.`0`}}!",
                "attachments": [
                    {
                        "cid": "employee_photo",
                        "data": "{{5.data}}",
                        "fileName": "{{5.name}}"
                    }
                ]
            },
            "metadata": {
